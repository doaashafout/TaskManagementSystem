<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.net.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="620.0" prefWidth="1000.0" styleClass="mainFxmlClass" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MainAppController">
    <stylesheets>
        <URL value="@/styles/MainAppStyle.css"/>
    </stylesheets>
    
    
   <top>
        <VBox spacing="10" styleClass="top-container">

            <Label text="Task Management System" styleClass="title-label">
                <font>
                    <Font name="Arial Black" size="24"/>
                </font>
                <padding>
                    <Insets left="20" top="10"/>
                </padding>
            </Label>

            <GridPane hgap="12" vgap="10" styleClass="form-container">
                <padding>
                    <Insets bottom="15" left="20" right="20" top="10"/>
                </padding>

                <Label text="Title:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="titleField" promptText="Enter task title"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Status:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <ComboBox fx:id="statusCombo" promptText="Select status"
                          GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                <Label text="Added By:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="addedByField" promptText="Enter user name"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Creation Date:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <DatePicker fx:id="datePicker"
                            GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                <Button text="Add Task" onAction="#addTaskHandle"
                        styleClass="btn-primary"
                        GridPane.columnIndex="4" GridPane.rowIndex="0"/>

                <Button text="Show All" onAction="#showAllHandle"
                        styleClass="btn-secondary"
                        GridPane.columnIndex="4" GridPane.rowIndex="1"/>
            </GridPane>

            <HBox spacing="15" styleClass="toolbar">
                <padding>
                    <Insets bottom="12" left="20" right="20" top="10"/>
                </padding>

                <Label text="Operation:"/>
                <ComboBox fx:id="operationBox"
                          onAction="#operationHandle"
                          prefWidth="280"
                          promptText="Choose operation"/>

                <Label text="User:"/>
                <TextField fx:id="searchUserField"
                           promptText="Ali / Sami"
                           prefWidth="160"/>
            </HBox>

        </VBox>
    </top>

    <center>
        <ListView fx:id="listView" styleClass="list-view-custom"/>
    </center>

    <bottom>
        <HBox styleClass="status-bar">
            <padding>
                <Insets bottom="8" left="20" right="20" top="8"/>
            </padding>

            <Label text="Ready" styleClass="status-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="taskNumber" text="0 tasks" styleClass="status-muted"/>
        </HBox>
    </bottom>

</BorderPane>
